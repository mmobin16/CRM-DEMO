# Copy these into Vercel → Settings → Environment Variables
# Do NOT include quotes around values

DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
AUTH_SECRET=your-long-random-secret-here

# AUTH_URL and NEXTAUTH_URL are auto-set on Vercel from next.config.ts
# Only set these manually if you use a custom domain:
# AUTH_URL=https://your-custom-domain.com
# NEXTAUTH_URL=https://your-custom-domain.com
